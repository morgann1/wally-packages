export type IconSize = "XSmall" | "Small" | "Medium" | "Large" | "XLarge" | "XXLarge"

local IconSizeEnum = {
	XSmall = "XSmall" :: "XSmall",
	Small = "Small" :: "Small",
	Medium = "Medium" :: "Medium",
	Large = "Large" :: "Large",
	-- Permitted for BuilderIcons in exceptional situations
	XLarge = "XLarge" :: "XLarge",
	XXLarge = "XXLarge" :: "XXLarge",
}

return IconSizeEnum
